{
  "name": "todo-desktop",
  "version": "1.1.6",
  "description": "Self-contained local-first desktop client for the To-Do board",
  "license": "MIT",
  "author": "todo-desktop contributors",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux",
    "dist:appimage": "electron-builder --linux AppImage",
    "dist:deb": "electron-builder --linux deb",
    "dist:snap": "electron-builder --linux snap"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3"
  },
  "overrides": {
    "tar": ">=7.5.16"
  },
  "build": {
    "appId": "com.todoapp.desktop",
    "productName": "To-Do",
    "files": ["main.js", "preload.js", "setup.html", "error.html", "icon.png", "ui/**/*"],
    "directories": { "buildResources": "build", "output": "release" },
    "publish": { "provider": "github", "releaseType": "release" },
    "linux": {
      "target": ["AppImage", "deb", "snap"],
      "category": "Utility",
      "icon": "build/icon.png",
      "maintainer": "todo-desktop contributors",
      "synopsis": "Self-contained local-first desktop client for the To-Do board",
      "desktop": { "entry": { "StartupWMClass": "To-Do" } }
    }
  }
}
