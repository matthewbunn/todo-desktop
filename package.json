{
  "name": "todo-desktop",
  "version": "1.0.1",
  "description": "Desktop client for the self-hosted To-Do board",
  "license": "MIT",
  "author": "todo-desktop contributors",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --linux",
    "dist:appimage": "electron-builder --linux AppImage",
    "dist:deb": "electron-builder --linux deb",
    "dist:snap": "electron-builder --linux snap"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.todoapp.desktop",
    "productName": "To-Do",
    "files": ["main.js", "preload.js", "setup.html", "error.html"],
    "directories": { "buildResources": "build", "output": "release" },
    "publish": { "provider": "github", "releaseType": "release" },
    "linux": {
      "target": ["AppImage", "deb", "snap"],
      "category": "Utility",
      "icon": "build/icon.png",
      "maintainer": "todo-desktop contributors",
      "synopsis": "Desktop client for the self-hosted To-Do board"
    }
  }
}
